# ── Xác thực HuggingFace (cần nếu model/dataset private) ─────────────────────
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Model ─────────────────────────────────────────────────────────────────────
# Đường dẫn local trên Network Volume (sau khi chạy download_model.py)
# MODEL_PATH=/workspace/base_model

# Repo HF để download (dùng trong download_model.py)
# MODEL_REPO=Qwen/Qwen2.5-7B

# ── Dataset ───────────────────────────────────────────────────────────────────
# HuggingFace Hub:
# DATASET_PATH=HuggingFaceH4/ultrachat_200k
# DATASET_SPLIT=train_sft
#
# Local JSONL (mỗi dòng: {"text": "..."} hoặc {"messages": [...]}):
# DATASET_PATH=/workspace/dataset/train.jsonl
#
# Tên cột chứa text (bỏ trống = tự detect: text > messages > content > prompt):
# DATASET_FIELD=text

# ── Output ────────────────────────────────────────────────────────────────────
# OUTPUT_DIR=/workspace/lora_output

# ── LoRA / QLoRA ──────────────────────────────────────────────────────────────
# USE_QLORA=true            # false = LoRA thuần (bf16, tốn VRAM hơn)
# LORA_R=16
# LORA_ALPHA=32
# LORA_DROPOUT=0.05
# TARGET_MODULES=q_proj,k_proj,v_proj,o_proj,gate_proj,up_proj,down_proj

# ── Training hyperparameters ──────────────────────────────────────────────────
# NUM_EPOCHS=3
# BATCH_SIZE=2
# GRAD_ACCUM=8              # effective batch = BATCH_SIZE * GRAD_ACCUM * n_gpu
# LR=2e-4
# MAX_SEQ_LEN=2048
# WARMUP_RATIO=0.03

# ── Flash Attention 2 (Ampere+ GPU: A100, RTX 3090, 4090, ...) ───────────────
# USE_FLASH_ATTN=true

# ── Logging (bỏ trống để bỏ qua wandb) ───────────────────────────────────────
# WANDB_PROJECT=my-finetune-project
# WANDB_API_KEY=
