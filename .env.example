# --- File .env trên MÁY BẠN (scripts/chat_runpod.py) — không cấu hình pod ---
# Chỉ cần URL HTTP của vLLM, KHÔNG dùng ssh.runpod.io (đó là SSH, không phải API).
# RunPod → Pods → pod → Connect → HTTP services → port 8000 → copy URL https://...
# Dán nguyên (có https://, thường có -8000 trong hostname). KHÔNG thêm /v1 — script tự nối.
# VLLM_BASE_URL=https://xxxxxxxx-8000.proxy.runpod.net

# Trùng MODEL_PATH trên pod (mặc định image)
# VLLM_MODEL=/workspace/qwen35-awq

# Chỉ cần nếu trên pod bạn set VLLM_API_KEY
# VLLM_API_KEY=

# Tuỳ chọn: câu mặc định khi chạy script không truyền tham số
# VLLM_PROMPT=2+2=?
# VLLM_MAX_TOKENS=4096

# Giới hạn ngữ cảnh / độ dài câu trả lời tối đa mỗi request (không phải context window của server).
# Context window thật do pod cấu hình: biến MAX_MODEL_LEN trên RunPod (mặc định image 200000 — xem README).

# --- Tải model (download_model.py) — repo HF private ---
# HF_TOKEN=
