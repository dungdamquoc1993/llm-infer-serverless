# ══════════════════════════════════════════════════════════════════════════════
# .env cho RunPod Pod (copy file này thành .env ở /root repo và điền giá trị)
# Chạy trước: cp scripts/.env.example .env  rồi chỉnh sửa
# ══════════════════════════════════════════════════════════════════════════════

# ── Xác thực HuggingFace ──────────────────────────────────────────────────────
# Bắt buộc nếu model hoặc dataset là private
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Model ─────────────────────────────────────────────────────────────────────
# Sau khi chạy download_model.py, dùng path local (nhanh hơn load từ Hub)
MODEL_PATH=/workspace/base_model

# Repo HF dùng để download (chỉ cần khi chạy download_model.py)
# Qwen3.5-9B: https://huggingface.co/Qwen/Qwen3.5-9B
# VRAM: BF16 ~19GB (inference only), 4-bit QLoRA ~6.5GB + overhead → tổng ~14–16GB ✓
MODEL_REPO=Qwen/Qwen3.5-9B

# ── Dataset ───────────────────────────────────────────────────────────────────
# Repo HF Hub (private) — chạy upload_dataset.py từ máy local trước
# Format: "username/repo-name" (split "train" và "validation" phải tồn tại)
HF_DATASET_REPO=your-username/shop-chat-sft

# Nếu không dùng HF Hub, bỏ trống HF_DATASET_REPO và để JSONL tại:
#   dataset/train.jsonl
#   dataset/val.jsonl
# (train.py sẽ tự fallback về local nếu HF_DATASET_REPO không được set)

# ── Output ────────────────────────────────────────────────────────────────────
# Thư mục lưu checkpoints và adapter cuối trên Network Volume
OUTPUT_DIR=/workspace/lora_output

# ── LoRA Adapter push (tùy chọn) ──────────────────────────────────────────────
# Nếu muốn push adapter lên HF Hub sau khi train xong
# ADAPTER_REPO=your-username/qwen3-5-shop-lora

# ── Merge adapter vào base model ─────────────────────────────────────────────
# true = merge LoRA adapter vào model gốc → full fine-tuned model (BF16, ~18 GB)
# Đây là bước bắt buộc để có model hoàn chỉnh cho inference/deploy
MERGE_MODEL=true

# Push merged model lên HF Hub (private) — dùng cho serverless inference sau này
# MERGED_REPO=your-username/qwen3-5-shop-merged

# ── QLoRA ─────────────────────────────────────────────────────────────────────
# USE_QLORA=true  → 4-bit NF4 (bitsandbytes) + LoRA  ← mặc định, tiết kiệm VRAM
# USE_QLORA=false → LoRA thuần bf16 (cần ~2x VRAM, chất lượng thường tốt hơn 1 chút)
USE_QLORA=true

# LoRA rank — quyết định số lượng tham số train được
# r=8:  ít tham số hơn, train nhanh, phù hợp data nhỏ
# r=16: cân bằng (recommended với ~2000 samples)
# r=32: nhiều tham số hơn, cần nhiều data và VRAM hơn
LORA_R=16

# alpha thường = 2×r hoặc bằng r; lora_alpha/r = "learning rate scale" của adapter
LORA_ALPHA=32

LORA_DROPOUT=0.05

# Modules áp dụng LoRA
# Qwen3.5-9B dùng kiến trúc hybrid (DeltaNet + Attention) → dùng "all-linear"
# để Unsloth tự detect đúng tên layers, không cần liệt kê thủ công
TARGET_MODULES=all-linear

# ── Training hyperparameters ──────────────────────────────────────────────────
# Với ~2400 samples và RTX 4000 Ada:
#   3 epochs × ~2400 / (batch=2 × accum=8) ≈ 450 update steps
NUM_EPOCHS=3

# Số sample mỗi forward pass trên 1 GPU
BATCH_SIZE=2

# Effective batch = BATCH_SIZE × GRAD_ACCUM = 16 (recommended cho SFT)
GRAD_ACCUM=8

# Learning rate — 2e-4 là điểm xuất phát tốt cho QLoRA
LR=2e-4

# Max token per sample — cắt bớt nếu hội thoại dài hơn
# Tăng lên 4096 nếu VRAM còn dư, giảm xuống 1024 nếu OOM
MAX_SEQ_LEN=2048

# Warmup: 3% đầu của tổng steps để LR tăng dần từ 0
WARMUP_RATIO=0.03

# ── Flash Attention 2 ─────────────────────────────────────────────────────────
# RTX 4000 Ada là Ada Lovelace (SM 89) → hỗ trợ FA2 → bật để train nhanh hơn
USE_FLASH_ATTN=true

# ── Thinking mode (Qwen3.5 specific) ─────────────────────────────────────────
# Qwen3.5-9B mặc định sinh <think>...</think> trước câu trả lời (reasoning mode)
# false = tắt thinking → model trả lời trực tiếp, phù hợp với SFT shop chat
# (data của chúng ta không có <think> blocks → phải tắt để format khớp)
ENABLE_THINKING=false

# ── Logging W&B (bỏ trống 2 dòng dưới để tắt hoàn toàn) ─────────────────────
# WANDB_PROJECT=shop-chat-finetune
# WANDB_API_KEY=your_wandb_api_key
